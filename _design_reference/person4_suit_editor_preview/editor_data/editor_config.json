      "available": true
    },
    {
      "id": "premium_black",
      "label": "Premium Black",
      "assetPath": "assets/fabrics/premium_black.png",
      "description": "Tecido premium exclusivo, acabamento acetinado",
      "priceModifier": 5000,
      "available": true
    }
