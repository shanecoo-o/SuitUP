    { "id": "buttons",      "angle": "front", "zOrder": 3, "canChangeColor": true,  "canChangeFabric": false, "visible": true,  "toggleable": true,  "assetPath": "assets/suit_layers/front/buttons.png" },
    { "id": "pockets",      "angle": "front", "zOrder": 4, "canChangeColor": true,  "canChangeFabric": true,  "visible": true,  "toggleable": true,  "assetPath": "assets/suit_layers/front/pockets.png" },
    { "id": "trousers",     "angle": "side",  "zOrder": 0, "canChangeColor": true,  "canChangeFabric": true,  "visible": true,  "toggleable": false, "assetPath": "assets/suit_layers/side/trousers.png" },
    { "id": "jacket_base",  "angle": "side",  "zOrder": 1, "canChangeColor": true,  "canChangeFabric": true,  "visible": true,  "toggleable": false, "assetPath": "assets/suit_layers/side/jacket_base.png" },
    { "id": "sleeve",       "angle": "side",  "zOrder": 2, "canChangeColor": true,  "canChangeFabric": true,  "visible": true,  "toggleable": true,  "assetPath": "assets/suit_layers/side/sleeve.png" },
    { "id": "trousers",     "angle": "back",  "zOrder": 0, "canChangeColor": true,  "canChangeFabric": true,  "visible": true,  "toggleable": false, "assetPath": "assets/suit_layers/back/trousers.png" },
    { "id": "jacket_base",  "angle": "back",  "zOrder": 1, "canChangeColor": true,  "canChangeFabric": true,  "visible": true,  "toggleable": false, "assetPath": "assets/suit_layers/back/jacket_base.png" },
    { "id": "collar",       "angle": "back",  "zOrder": 2, "canChangeColor": true,  "canChangeFabric": true,  "visible": true,  "toggleable": true,  "assetPath": "assets/suit_layers/back/collar.png" }
  ],

  "sliders": [
    {
      "id": "lapela",
      "label": "Lapela",
      "min": 0, "max": 100, "defaultValue": 50, "step": 1, "unit": "%",
      "targetLayers": ["lapel"],
      "composeProperty": "scaleX",
      "scaleRange": { "min": 0.5, "max": 1.5 }
    },
    {
      "id": "comprimento",
      "label": "Comprimento",
      "min": 0, "max": 100, "defaultValue": 60, "step": 1, "unit": "%",
      "targetLayers": ["jacket_base", "sleeve"],
      "composeProperty": "scaleY",
      "scaleRange": { "min": 0.7, "max": 1.3 }
    },
    {
      "id": "ombro",
      "label": "Ombro",
      "min": 0, "max": 100, "defaultValue": 45, "step": 1, "unit": "%",
      "targetLayers": ["jacket_base"],
      "composeProperty": "scaleX",
      "scaleRange": { "min": 0.85, "max": 1.25 }
    }
  ],

  "suitModels": [
    { "id": "classic_suit",  "label": "Classic Suit",  "basePrice": 12500 },
    { "id": "slim_fit",      "label": "Slim Fit",      "basePrice": 13500 },
    { "id": "double_breast", "label": "Double Breast", "basePrice": 15000 },
    { "id": "tuxedo",        "label": "Tuxedo",        "basePrice": 18000 }
