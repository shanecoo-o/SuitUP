  "fabrics": [
    {
      "id": "wool",
      "label": "Wool",
      "assetPath": "assets/fabrics/wool.png",
      "description": "Lã merino premium, ideal para clima frio",
      "priceModifier": 0,
      "available": true
    },
    {
      "id": "cotton",
      "label": "Cotton",
      "assetPath": "assets/fabrics/cotton.png",
