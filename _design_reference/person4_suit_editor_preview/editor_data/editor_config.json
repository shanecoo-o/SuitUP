    { "id": "rust",      "hex": "#7a2a1a", "label": "Rust",         "premium": true  },
    { "id": "olive",     "hex": "#3d4a1a", "label": "Olive",        "premium": false },
    { "id": "slate",     "hex": "#3a4a5c", "label": "Slate",        "premium": false },
    { "id": "sand",      "hex": "#d4c4a0", "label": "Sand",         "premium": false }
