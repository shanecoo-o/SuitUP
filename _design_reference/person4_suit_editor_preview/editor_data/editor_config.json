    { "id": "trousers",     "angle": "front", "zOrder": 0, "canChangeColor": true,  "canChangeFabric": true,  "visible": true,  "toggleable": false, "assetPath": "assets/suit_layers/front/trousers.png" },
    { "id": "jacket_base",  "angle": "front", "zOrder": 1, "canChangeColor": true,  "canChangeFabric": true,  "visible": true,  "toggleable": false, "assetPath": "assets/suit_layers/front/jacket_base.png" },
